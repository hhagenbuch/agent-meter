{
  "uid": "agent-meter",
  "title": "agent-meter — LLM cost & budgets",
  "tags": ["agent-meter", "finops", "llm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total spend (window)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "expr": "sum(agent_cost_usd_total)", "legendFormat": "total" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cost by feature ($/min)",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "fillOpacity": 20 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        { "refId": "A", "expr": "sum by (agent_feature) (rate(agent_cost_usd_total[1m]) * 60)", "legendFormat": "{{agent_feature}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Tokens by model (tok/min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        { "refId": "A", "expr": "sum by (gen_ai_response_model, direction) (rate(agent_tokens_total[1m]) * 60)", "legendFormat": "{{gen_ai_response_model}} {{direction}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Budget enforcements (warn / degrade / block)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "sum by (agent_budget_action) (rate(agent_budget_enforced_total[5m]))", "legendFormat": "{{agent_budget_action}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Turn duration p95 (ms)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_turn_duration_milliseconds_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Unknown-model calls (cost recorded as unknown, not $0)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(agent_cost_unknown_model_total[5m]))", "legendFormat": "unknown/s" }
      ]
    }
  ]
}
